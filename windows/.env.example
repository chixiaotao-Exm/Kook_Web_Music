# KOOK Web Music 环境变量配置
# 复制此文件为 .env 并填入实际值

# 服务器配置
HOST=0.0.0.0
PORT=5000
DEBUG=False

# KOOK Bot Token（必填）
BOT_TOKEN=your_bot_token_here

# Flask 密钥（必填，用于 session 加密）
SECRET_KEY=change-this-to-a-random-secret-string

# ffmpeg / ffprobe 路径
FFMPEG_PATH=C:/ffmpeg/bin/ffmpeg.exe
FFPROBE_PATH=C:/ffmpeg/bin/ffprobe.exe

# 音乐 API 基础 URL
MUSIC_API_BASE=http://localhost:3000
